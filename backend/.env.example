# Configurações do backend Dirceu — copie para .env e ajuste conforme necessário.

# URL do banco. Dev: SQLite (arquivo local). Prod: PostgreSQL.
DATABASE_URL=sqlite:///./dirceu.db

# Segredo usado para assinar os tokens JWT. TROQUE em produção.
SECRET_KEY=dev-trocar-em-producao

# Validade do token de acesso, em minutos (10080 = 7 dias).
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Usuário e senha do admin inicial (criados no seed).
ADMIN_USERNAME=dirceu
ADMIN_PASSWORD=trocar-senha

# Pasta onde fotos e logo são salvos.
MEDIA_DIR=./media

# Origens permitidas no CORS. "*" libera todas; ou lista separada por vírgula.
CORS_ORIGINS=*
