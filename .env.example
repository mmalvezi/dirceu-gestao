# Produção do Dirceu — copie para .env NO SERVIDOR e preencha.
# ATENÇÃO: senhas SÓ com letras e números — '@' e afins QUEBRAM a DATABASE_URL!

# Postgres (container db)
POSTGRES_USER=dirceu
POSTGRES_PASSWORD=troque-por-senha-so-letras-e-numeros
POSTGRES_DB=dirceu

# URL usada pela API — a senha deve ser A MESMA de POSTGRES_PASSWORD
DATABASE_URL=postgresql+psycopg2://dirceu:MESMA_SENHA_AQUI@db:5432/dirceu

# Segredo dos tokens JWT — gere com: openssl rand -hex 32
SECRET_KEY=gere-com-openssl-rand-hex-32

# Validade do token (10080 = 7 dias)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Admin inicial (criado no primeiro start)
ADMIN_USERNAME=dirceu
ADMIN_PASSWORD=troque-a-senha-do-dirceu

# Mídia (volume media_data montado no container)
MEDIA_DIR=/app/media

# CORS vazio: front e API no MESMO domínio (nginx faz o proxy /api)
CORS_ORIGINS=
